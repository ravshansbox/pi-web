{
  "name": "pi-web",
  "version": "0.0.0",
  "type": "module",
  "description": "Web UI for the pi coding agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravshansbox/pi-web.git"
  },
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "license": "MIT",
  "keywords": [
    "pi",
    "web",
    "ui"
  ],
  "files": [
    "bin",
    "dist",
    "build/server",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "npm run dev:pi",
    "dev:pi": "concurrently \"vite build --watch\" \"tsc -w -p tsconfig.server.json\" \"node --watch build/server/server.js --agent pi\"",
    "dev:omp": "concurrently \"vite build --watch\" \"tsc -w -p tsconfig.server.json\" \"node --watch build/server/server.js --agent omp\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:bin": "node scripts/generate-bin.mjs",
    "test:smoke": "node scripts/smoke-checks.mjs",
    "preview": "vite preview",
    "start": "node build/server/server.js",
    "prepack": "npm run build && npm run build:bin",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  }
}
